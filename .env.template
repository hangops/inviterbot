# Slack Configuration
SLACK_SUBDOMAIN=your-workspace
SLACK_API_TOKEN=xoxb-your-bot-token
# Legacy alias for SLACK_API_TOKEN (deprecated, use SLACK_API_TOKEN)
# SLACK_BOT_TOKEN=xoxb-your-bot-token

# Invite Mode: 'api' (Enterprise Grid with admin.users:write) or 'link' (standard workspaces)
SLACK_INVITE_MODE=link
# For 'link' mode: URL to redirect users (generate at https://your-workspace.slack.com/admin/invites)
SLACK_INVITE_URL=https://join.slack.com/t/your-workspace/shared_invite/...

# reCAPTCHA (optional but recommended to prevent abuse)
RECAPTCHA_SECRET=your-recaptcha-secret
RECAPTCHA_SITEKEY=your-recaptcha-sitekey
RECAPTCHA_INVISIBLE=false

# Code of Conduct (optional - URL to your CoC that users must agree to)
SLACKIN_COC=https://example.com/code-of-conduct

# Channels (optional - comma-separated list of channels users can join)
SLACKIN_CHANNELS=general,random

# User count refresh interval in milliseconds (default: 60000)
SLACKIN_INTERVAL=60000

# Google Analytics tracking ID (optional)
SLACKIN_ANALYTICS=UA-XXXXX-Y

# Theme: 'light' or 'dark' (default: 'light')
SLACKIN_THEME=light

# Accent color (optional - hex color for buttons/links)
SLACKIN_ACCENT=#e01563

# Let's Encrypt challenge (optional - for ACME validation)
# SLACKIN_LETSENCRYPT=your-letsencrypt-challenge
